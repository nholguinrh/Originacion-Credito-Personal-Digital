      </mxGeometry>
    </mxCell>

    <!-- 4. SAP interno: validar + GUID -->
    <mxCell id="sap_proc1" value="4. Valida OAuth2, genera correlationId (GUID)&#xa;Registra en log de auditoría" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="615" y="280" width="200" height="40" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════ -->
