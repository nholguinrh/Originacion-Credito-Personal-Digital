      <mxGeometry x="325" y="215" width="150" height="30" as="geometry" />
    </mxCell>

    <!-- 3. SF → SAP -->
    <mxCell id="msg3" value="3. POST /credit-applications/initiate&#xa;{ customerId, amount, term, caseId }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;strokeWidth=2;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
