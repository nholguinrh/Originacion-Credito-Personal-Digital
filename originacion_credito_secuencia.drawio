        <mxPoint x="1000" y="430" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- 6. Biometría → SAP: OK -->
    <mxCell id="msg6" value="6. HTTP 200 OK — { biometricToken, score: 0.97, status: APPROVED }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
