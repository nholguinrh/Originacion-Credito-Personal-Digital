      <mxGeometry x="100" y="395" width="300" height="20" as="geometry" />
    </mxCell>

    <!-- 5. SAP → Biometría -->
    <mxCell id="msg5" value="5. POST /identity/validate&#xa;{ correlationId, customerId, selfieBase64, documentScan }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
