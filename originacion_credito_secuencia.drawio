    <!-- ═══════════════════════════════════════════ -->
    <mxCell id="fase2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;opacity=20;arcSize=5;" vertex="1" parent="1">
