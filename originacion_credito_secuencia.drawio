    <mxCell id="msg16" value="16. POST /loans/applications (reintento — Idempotency-Key: {correlationId})" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;endArrow=block;endFill=1;dashed=1;" edge="1" parent="1">
