    </mxCell>
    <mxCell id="msg1" value="1. Envía formulario&#xa;(nombre, doc, monto, plazo)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
