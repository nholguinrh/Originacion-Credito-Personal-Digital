        <mxPoint x="1300" y="750" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- timeout X -->
    <mxCell id="timeout_x" value="⏱ TCP Timeout (30s)&#xa;Connection Refused" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=1;fontColor=#c0392b;" vertex="1" parent="1">
      <mxGeometry x="1060" y="735" width="200" height="40" as="geometry" />
    </mxCell>

    <!-- 13. SAP interno: captura error -->
    <mxCell id="sap_proc3" value="13. Captura TimeoutException&#xa;Estado = PENDING_RETRY&#xa;Persiste payload + biometricToken en JMS Queue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="600" y="800" width="210" height="50" as="geometry" />
    </mxCell>

    <!-- 14. SAP → SF: 202 -->
    <mxCell id="msg14" value="14. HTTP 202 Accepted — { status: PENDING_CORE, estimatedRetry: 5min }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
