    <!-- 1. Cliente → SF: formulario -->
    <mxCell id="m1" value="1. Envía formulario&#xa;(nombre, doc, monto, plazo)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;align=center;" edge="1" parent="1" source="hdr_cliente" target="hdr_sf">
