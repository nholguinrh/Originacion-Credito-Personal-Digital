    <mxCell id="msg11" value="11. ✅ Solicitud registrada. N° LAP-XXXXXX" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="400" y="680" as="sourcePoint" />
        <mxPoint x="160" y="680" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- ═══════════════════════════════════════════ -->
