    <mxCell id="fase3_lbl" value="FASE 3A — Registro en Core Bancario (✅ Flujo Exitoso)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#1a3a6e;" vertex="1" parent="1">
      <mxGeometry x="100" y="565" width="400" height="20" as="geometry" />
    </mxCell>

    <!-- 8. SAP → Core -->
    <mxCell id="msg8" value="8. POST /loans/applications&#xa;{ correlationId, customer, amount, term, biometricToken }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
