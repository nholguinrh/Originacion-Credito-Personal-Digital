    <!-- 15. SF → Cliente: 202 -->
    <mxCell id="msg15" value="15. ⏳ Solicitud recibida, procesando... Ref: GUID" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
