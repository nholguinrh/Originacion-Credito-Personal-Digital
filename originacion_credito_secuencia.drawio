        <mxPoint x="400" y="900" as="sourcePoint" />
        <mxPoint x="160" y="900" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- RETRY LOOP BOX -->
    <mxCell id="retry_box" value="🔁 Retry Policy: máx 3 intentos — Backoff exponencial: 5 / 15 / 30 min&#xa;Idempotency-Key = correlationId (evita duplicados)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#f9a825;fontSize=11;fontStyle=1;arcSize=5;" vertex="1" parent="1">
      <mxGeometry x="560" y="920" width="500" height="45" as="geometry" />
    </mxCell>

