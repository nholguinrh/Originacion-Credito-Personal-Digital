    <!-- 9. Core → SAP: 201 -->
    <mxCell id="msg9" value="9. HTTP 201 Created — { loanApplicationId, status: PENDING_REVIEW }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="1300" y="630" as="sourcePoint" />
        <mxPoint x="690" y="630" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- 10. SAP → SF -->
    <mxCell id="msg10" value="10. HTTP 200 OK — { correlationId, loanApplicationId, status: REGISTERED }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
