    <mxCell id="fase3err_lbl" value="FASE 3B — ⚠️ Core Bancario fuera de línea (Timeout / Connection Refused)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#c0392b;" vertex="1" parent="1">
      <mxGeometry x="100" y="715" width="600" height="20" as="geometry" />
    </mxCell>

    <!-- 12. SAP → Core: timeout -->
    <mxCell id="msg12" value="12. POST /loans/applications (intento)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
