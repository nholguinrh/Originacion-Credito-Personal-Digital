    <!-- ═══════════════════════════════════════════ -->
    <mxCell id="dlq_box" value="⛔ Si se agotan 3 reintentos:&#xa;Mensaje → Dead Letter Queue (DLQ)&#xa;Alerta en SAP Alert Management&#xa;SF: status = FAILED_CORE_UNAVAILABLE&#xa;Cliente: &quot;Un asesor te contactará en 1 hora&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcccc;strokeColor=#cc0000;fontSize=11;fontStyle=1;arcSize=5;" vertex="1" parent="1">
