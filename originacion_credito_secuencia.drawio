    <!-- 17. Core → SAP: recovered -->
    <mxCell id="msg17" value="17. HTTP 201 Created (Core recuperado)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=2;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="1300" y="1010" as="sourcePoint" />
        <mxPoint x="690" y="1010" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <!-- 18. SAP → SF: PATCH -->
    <mxCell id="msg18" value="18. PATCH /cases/{caseId} → { status: REGISTERED, loanApplicationId }" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
